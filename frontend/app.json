{
  "expo": {
    "name": "Sudoku Tiles Pro",
    "slug": "zoo-tiles",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chamal.sudokutiles",
      "bundleDisplayName": "Sudoku Tiles Pro",
      "googleServicesFile": "./GoogleService-Info.plist",
      "usesAppleSignIn": true,
      "deploymentTarget": "15.1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.136934864636-43ektognl9thv2rva0l37k1s3joutd4m"
            ]
          }
        ],
        "LSApplicationQueriesSchemes": [
          "whatsapp",
          "tg",
          "telegram",
          "fb-messenger",
          "fb",
          "fbshareextension",
          "twitter",
          "twitterrific",
          "tweetbot",
          "instagram",
          "instagram-stories",
          "tiktok",
          "snapchat",
          "linkedin",
          "linkedin-sdk2",
          "linkedin-sdk",
          "reddit",
          "discord",
          "sms",
          "mailto",
          "googlechrome",
          "safari"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.chamal.sudokutiles",
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": ["BROWSABLE", "DEFAULT"],
          "data": [
            {
              "scheme": "https",
              "host": "*.whatsapp.com"
            },
            {
              "scheme": "https",
              "host": "*.telegram.org"
            },
            {
              "scheme": "https",
              "host": "*.fb.com"
            },
            {
              "scheme": "https",
              "host": "*.twitter.com"
            },
            {
              "scheme": "https",
              "host": "*.instagram.com"
            },
            {
              "scheme": "https",
              "host": "*.tiktok.com"
            },
            {
              "scheme": "https",
              "host": "*.snapchat.com"
            },
            {
              "scheme": "https",
              "host": "*.linkedin.com"
            },
            {
              "scheme": "https",
              "host": "*.reddit.com"
            },
            {
              "scheme": "https",
              "host": "*.discord.com"
            }
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "36f6c24d-d1e0-4c82-b494-baedb1991208"
      }
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "deploymentTarget": "15.1"
          }
        }
      ],
      "expo-apple-authentication",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "owner": "ckayssar1"
  }
}