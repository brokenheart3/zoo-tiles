{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",           // Changed from "ES2020" to "Node16"
    "moduleResolution": "Node16", // Kept as "Node16"
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}